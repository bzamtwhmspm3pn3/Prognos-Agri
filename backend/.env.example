# ============================================
# PROGNOS AGRI 2.0 — Configuração de Ambiente
# ============================================

# Servidor
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/prognos-agri

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=30d

# Frontend
FRONTEND_URL=http://localhost:3000

# Python API (YOLO Detection)
PYTHON_API_URL=http://localhost:8001

# Weather API (OpenWeatherMap ou similar)
WEATHER_API_KEY=your_weather_api_key

# JIAM Predictivo API
JIAM_API_URL=https://api.jiam-predictivo.com
JIAM_API_KEY=your_jiam_api_key

# Blockchain (opcional)
BLOCKCHAIN_PROVIDER_URL=
BLOCKCHAIN_CONTRACT_ADDRESS=
